SECRET_KEY=change-me
DEBUG=1
DATABASE_URL=
FRONTEND_ORIGINS=https://your-frontend.example
ADMIN_PATH=admin
API_ANON_RATE=120/minute
API_USER_RATE=600/minute
SECURE_HSTS_SECONDS=31536000

# Choose ONE media backend:
#
# 1) Cloudinary (recommended free plan)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or set the three values separately:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# 2) S3-compatible storage (optional)
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=
